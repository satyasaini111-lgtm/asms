      "description": "Multi-stage approval workflows using Chain of Responsibility pattern",
      "item": [
        {
          "name": "Submit Approval Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) pm.collectionVariables.set('workflowId', json.id);",
                  "    pm.test('Workflow submitted', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requesterId\": \"{{userId}}\",\n  \"societyId\": \"{{societyId}}\",\n  \"workflowType\": \"MAINTENANCE_REQUEST\",\n  \"documentType\": \"WORK_ORDER\",\n  \"description\": \"Replacement of water pump in Block A\",\n  \"metadata\": {\n    \"estimatedCost\": 15000,\n    \"vendorId\": \"VENDOR-001\",\n    \"urgency\": \"HIGH\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/workflows",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "workflows"]
            },
            "description": "WorkflowType: VENDOR_ONBOARDING, MAINTENANCE_REQUEST, LEASE_RENEWAL, CONSTRUCTION_PERMIT, FACILITY_BOOKING\nProcessed through Chain of Responsibility: Security → RWA → Admin"
          }
        },
