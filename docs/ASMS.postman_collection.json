    {
      "name": "03 - Support Tickets",
      "description": "Support ticket lifecycle: raise → assign → resolve → close",
      "item": [
        {
          "name": "Create Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) pm.collectionVariables.set('ticketId', json.id);",
                  "    pm.test('Ticket created', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Water leakage in bathroom\",\n  \"description\": \"There is a water leakage from the ceiling in the master bedroom bathroom. It has been ongoing for 3 days.\",\n  \"category\": \"PLUMBING\",\n  \"priority\": \"P2_HIGH\",\n  \"societyId\": \"{{societyId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets"]
            },
            "description": "Requires OWNER or TENANT role.\nCategory: PLUMBING, ELECTRICAL, CARPENTRY, HOUSEKEEPING, SECURITY, LIFT, WATER_SUPPLY, INTERNET, PARKING, COMMON_AREA, OTHER\nPriority: P1_CRITICAL, P2_HIGH, P3_MEDIUM, P4_LOW"
          }
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}"]
            },
            "description": "Requires ADMIN, RWA_MEMBER, SUPPORT_STAFF, OWNER, or TENANT role."
          }
        },
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets?societyId={{societyId}}&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets"],
              "query": [
                { "key": "societyId", "value": "{{societyId}}" },
                { "key": "status", "value": "OPEN", "disabled": true },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Requires ADMIN, RWA_MEMBER, SUPPORT_STAFF, OWNER, or TENANT role. Results are filtered by role."
          }
        },
        {
          "name": "Assign Ticket",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/assign?assignedToUserId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "assign"],
              "query": [
                { "key": "assignedToUserId", "value": "{{userId}}" }
              ]
            },
            "description": "Requires ADMIN or RWA_MEMBER role. Assigns ticket to a SUPPORT_STAFF user."
          }
        },
        {
          "name": "Resolve Ticket",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/resolve?resolutionNote=Plumber fixed the pipe. Issue resolved.",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "resolve"],
              "query": [
                { "key": "resolutionNote", "value": "Plumber fixed the pipe. Issue resolved." }
              ]
            },
            "description": "Requires ADMIN, RWA_MEMBER, or SUPPORT_STAFF role."
          }
        },
        {
          "name": "Close Ticket",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/close",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "close"]
            },
            "description": "Requires ADMIN or RWA_MEMBER role. Ticket must be in RESOLVED state first."
          }
        }
      ]
    },
    {
      "name": "04 - Visitors",
      "description": "Visitor entry lifecycle: log → approve/reject (resident) → check-in → check-out (security)",
      "item": [
        {
          "name": "Log Visitor Entry",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) pm.collectionVariables.set('visitorId', json.id);",
                  "    pm.test('Visitor logged', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visitorName\": \"Ravi Kumar\",\n  \"visitorPhone\": \"9123456789\",\n  \"vehicleNumber\": \"MH12AB1234\",\n  \"purpose\": \"Delivery\",\n  \"societyId\": \"{{societyId}}\",\n  \"residentUserId\": \"{{userId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/visitors",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "visitors"]
            },
            "description": "Requires SECURITY role. Security guard logs the visitor at the gate."
          }
        },
        {
          "name": "Approve Visitor",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/visitors/{{visitorId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "visitors", "{{visitorId}}", "approve"]
            },
            "description": "Requires OWNER or TENANT role. Resident approves the visitor entry."
          }
        },
        {
          "name": "Reject Visitor",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/visitors/{{visitorId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "visitors", "{{visitorId}}", "reject"]
            },
            "description": "Requires OWNER or TENANT role. Resident rejects the visitor entry."
          }
        },
        {
          "name": "Check In Visitor",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/visitors/{{visitorId}}/checkin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "visitors", "{{visitorId}}", "checkin"]
            },
            "description": "Requires SECURITY role. Must be APPROVED first."
          }
        },
        {
          "name": "Check Out Visitor",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/visitors/{{visitorId}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "visitors", "{{visitorId}}", "checkout"]
            },
            "description": "Requires SECURITY role. Records visitor departure time."
          }
        },
        {
          "name": "List Visitors by Society",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/visitors?societyId={{societyId}}&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "visitors"],
              "query": [
