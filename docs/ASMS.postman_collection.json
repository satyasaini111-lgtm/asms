                  "    const json = pm.response.json();",
                  "    if (json.id) pm.collectionVariables.set('amenityId', json.id);",
                  "    pm.test('Amenity created', () => pm.response.to.have.status(201));",
                  "}"
                ],
                "type": "text/javascript"
