              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/amenities",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "amenities"]
            },
            "description": "AmenityType enum: SWIMMING_POOL, GYM, CLUBHOUSE, TENNIS_COURT, BADMINTON_COURT, BANQUET_HALL, LIBRARY, KIDS_PLAY_AREA, TERRACE, OTHER"
          }
        },
        {
          "name": "Get Amenity by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/amenities/{{amenityId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "amenities", "{{amenityId}}"]
